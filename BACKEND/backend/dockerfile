# ✅ Python 3.8 기반 경량 컨테이너
FROM python:3.8-slim  

# ✅ 작업 디렉토리 설정
WORKDIR /app

# ✅ 필수 패키지 설치 (MySQL & SQLAlchemy 연동)
RUN apt-get update && apt-get install -y \
    gcc \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# ✅ 종속성 설치
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# ✅ 환경 변수 로드 (AWS RDS 연동)
COPY . .

# ✅ FastAPI 실행 (AWS 환경에서 실행)
CMD ["sh", "-c", "ENV_MODE=aws uvicorn main:app --host 0.0.0.0 --port 8000"]
