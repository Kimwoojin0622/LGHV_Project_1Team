# ✅ 1. Node.js 18 기반 이미지 사용
FROM node:18-alpine AS builder

# ✅ 2. 작업 디렉토리 설정
WORKDIR /app

# ✅ 3. package.json과 package-lock.json 복사
COPY package.json package-lock.json ./

# ✅ 4. 의존성 설치 (npm 사용)
RUN npm ci  # ✅ package-lock.json이 있을 경우 캐시 없이 설치

# ✅ 5. 소스 코드 복사 후 빌드 실행
COPY . .
RUN npm run build  # ✅ Next.js 프로젝트 빌드

# ✅ 6. 런타임 환경으로 변경 후 실행
FROM node:18-alpine
WORKDIR /app
COPY --from=builder /app ./
CMD ["npm", "start"]
